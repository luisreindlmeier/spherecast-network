# Anthropic Claude Messages API
# Create a local .env.local and set these values there.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (used by FDA facility scraper if ANTHROPIC_API_KEY is not set)
OPENAI_API_KEY=

# Agnes Backend API
AGNES_API_URL=https://agnes-supply-chain.onrender.com
AGNES_API_KEY=

# Google Maps (Places API + Geocoding API — used by geocode-entities.ts script)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Similarity Map: log Plotly scene.camera on orbit/zoom (browser console). Restart dev after change.
NEXT_PUBLIC_SIMILARITY_MAP_CAMERA_DEBUG=
# (accepted: true, 1, yes — case-insensitive)
